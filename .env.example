SECRET_KEY=replace-with-a-long-random-secret
ADMIN_TOKEN=replace-with-admin-token
DEBUG=false
HOST=0.0.0.0
PORT=5000

GOOGLE_AI_STUDIO_API_KEY=
GOOGLE_AI_MODEL=gemini-flash-latest
GOOGLE_AI_FALLBACK_MODEL=gemini-2.5-flash
GOOGLE_AI_MAX_RETRIES=2
GOOGLE_AI_RETRY_BACKOFF_SECONDS=1.25
GOOGLE_AI_MAX_CONCURRENT_REQUESTS=3
GOOGLE_AI_TIMEOUT=20

DEFAULT_AUTO_TRANSLATE=true

RATE_LIMIT_DEFAULT=20 per minute
RATE_LIMIT_REWRITE=30 per minute
RATE_LIMIT_STORAGE_URI=memory://
ENFORCE_API_KEYS=false
TRUST_X_FORWARDED_FOR=false

BATCH_MAX_ITEMS=100
BATCH_MAX_TEXT_LENGTH=4000

TEMPLATES_AUTO_RELOAD=true
DISABLE_HTML_CACHE=true
